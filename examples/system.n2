# n2-ark System Administration Safety Rules
# For AI agents managing servers, infrastructure, or deployments.

# ── State Machine: Deployment Sequence ──

@contract deploy_sequence {
    idle -> building : on build_start
    building -> testing : on run_tests
    testing -> staging : on deploy_staging
    staging -> approved : on deploy_approval
    approved -> production : on deploy_production
}

# ── Blacklist: Infrastructure Destruction ──

@rule infra_blacklist {
    scope: tool_call
    blacklist: [
        /terraform\s+destroy/i,
        /kubectl\s+delete\s+namespace/i,
        /docker\s+system\s+prune\s+-a/i,
        /aws\s+.*\s+delete/i,
        /gcloud\s+.*\s+delete/i,
        /DROP\s+DATABASE/i
    ]
    requires: human_approval
}

# ── Gate: Production Access ──

@gate production_access {
    actions: [deploy_production, rollback_production, scale_down, terminate_instance]
    requires: human_approval
    min_approval_level: 2
}
