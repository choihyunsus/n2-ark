# n2-ark Military Safety Rules
# For AI agents in defense: engagement, weapons, intelligence.
# Enforces strict chain of command — no unauthorized use of force.

# ── State Machine: Engagement Sequence ──
# No weapon system can fire without full authorization chain.
# AI cannot skip identification → authorization → engagement.

@contract engagement_sequence {
    standby -> identified : on target_identified
    identified -> verified : on target_verified
    verified -> authorized : on commander_approval
    authorized -> engaging : on execute_engagement
    engaging -> standby : on engagement_complete
}

# ── State Machine: Nuclear Protocol ──
# Absolute strictest sequence. Requires dual-key authorization.

@contract nuclear_protocol {
    safe -> alert : on threat_detected
    alert -> confirmed : on threat_confirmed
    confirmed -> first_key : on first_key_authorization
    first_key -> dual_key : on second_key_authorization
    dual_key -> armed : on system_armed
    armed -> safe : on stand_down
}

# ── Blacklist: Weapons & Force ──
# Block ALL use-of-force actions unconditionally.

@rule weapons_blacklist {
    scope: tool_call
    blacklist: [
        /fire\s+(weapon|missile|torpedo)/i,
        /launch\s+(missile|strike|attack)/i,
        /engage\s+(target|hostile|enemy)/i,
        /detonate/i,
        /deploy\s+(munition|bomb|mine)/i,
        /activate\s+(warhead|weapon)/i,
        /arm\s+(missile|weapon|device)/i,
        /lethal\s+(force|action|strike)/i,
        /airstrike/i,
        /bombardment/i
    ]
    requires: commander_approval
}

# ── Blacklist: Intelligence & Classified ──
# Prevents unauthorized handling of classified information.

@rule classified_data {
    scope: api_call
    blacklist: [
        /classified\s+(document|data|intel)\s+(send|share|export|leak)/i,
        /top\s+secret/i,
        /SCI\s+(transfer|transmit)/i,
        /troop\s+(movement|position)\s+(share|broadcast)/i,
        /decrypt\s+comms/i,
        /surveillance\s+(target|civilian)/i,
        /interrogat/i
    ]
    requires: commander_approval
}

# ── Gate: Lethal Force Authorization ──
# All lethal actions require dual-level (2+) commander approval.

@gate lethal_force {
    actions: [execute_engagement, launch_missile, deploy_munition, activate_warhead, authorize_strike]
    requires: commander_approval
    min_approval_level: 2
}
