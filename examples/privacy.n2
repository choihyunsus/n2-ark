# n2-ark Privacy & Compliance Safety Rules
# For AI agents handling personal data: GDPR, CCPA, PIPA, HIPAA.
# Prevents unauthorized collection, processing, or sharing of PII.

# ── State Machine: Data Processing Sequence ──
# No personal data processing without consent verification.

@contract data_processing_sequence {
    idle -> consent_requested : on request_consent
    consent_requested -> consent_granted : on user_consent
    consent_granted -> processing : on process_data
    processing -> idle : on processing_complete
}

# ── State Machine: Data Deletion (Right to be Forgotten) ──
# Deletion requests must follow proper verification flow.

@contract data_deletion_sequence {
    idle -> requested : on deletion_request
    requested -> identity_verified : on verify_identity
    identity_verified -> approved : on deletion_approval
    approved -> deleted : on execute_deletion
    deleted -> idle : on deletion_confirmed
}

# ── Blacklist: PII Operations ──
# Block all operations involving personally identifiable information.

@rule pii_protection {
    scope: api_call
    blacklist: [
        /collect\s+(email|phone|address|ssn|passport)/i,
        /personal\s+(data|info)\s+(send|share|export|sell)/i,
        /PII\s+(transfer|transmit|export)/i,
        /social\s+security/i,
        /credit\s+card\s+number/i,
        /biometric\s+(data|scan|collect)/i,
        /facial\s+recognition/i,
        /location\s+(track|monitor|share)/i,
        /browsing\s+(history|data)\s+(collect|share|sell)/i
    ]
    requires: human_approval
}

# ── Blacklist: Cross-Border Data Transfer ──
# GDPR Article 44-49: Restrictions on international data transfers.

@rule cross_border_transfer {
    scope: api_call
    blacklist: [
        /transfer\s+(to|outside)\s+(EU|EEA|country)/i,
        /cross.?border\s+(data|transfer)/i,
        /data\s+(export|migration)\s+(international|foreign)/i,
        /third.?party\s+(share|data|access)/i,
        /data\s+broker/i
    ]
    requires: human_approval
}

# ── Blacklist: Cookie & Tracking ──
# Prevents unauthorized tracking and profiling.

@rule tracking_protection {
    scope: tool_call
    blacklist: [
        /set\s+cookie/i,
        /tracking\s+(pixel|script|beacon)/i,
        /fingerprint\s+(browser|device)/i,
        /user\s+profil(e|ing)\s+(create|build|update)/i,
        /analytics\s+(inject|install)/i,
        /retarget/i
    ]
    requires: human_approval
}

# ── Gate: Data Processing Decisions ──
# Critical data operations always need explicit consent.

@gate data_operations {
    actions: [process_data, delete_user_data, export_user_data, share_with_third_party, create_user_profile]
    requires: human_approval
    min_approval_level: 1
}
