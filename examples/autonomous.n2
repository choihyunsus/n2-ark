# n2-ark Autonomous Vehicle Safety Rules
# For AI agents controlling vehicles: self-driving, drones, robotics.
# Enforces safety-critical sequences — no shortcuts to critical maneuvers.

# ── State Machine: Autonomous Driving Sequence ──
# Vehicle AI must follow proper initialization before any driving.

@contract driving_sequence {
    parked -> initializing : on system_startup
    initializing -> sensor_check : on run_diagnostics
    sensor_check -> ready : on diagnostics_passed
    ready -> driving : on engage_autonomous
    driving -> stopping : on disengage_autonomous
    stopping -> parked : on vehicle_stopped
}

# ── State Machine: Emergency Override ──
# Emergency situations must go through proper escalation.

@contract emergency_sequence {
    normal -> alert : on hazard_detected
    alert -> human_notified : on notify_operator
    human_notified -> override_active : on operator_override
    override_active -> normal : on hazard_cleared
}

# ── Blacklist: Vehicle Control ──
# Block dangerous vehicle control actions.

@rule vehicle_control_blacklist {
    scope: tool_call
    blacklist: [
        /disable\s+(brake|braking|ABS|ESC|traction)/i,
        /override\s+(speed\s+limit|safety\s+limit)/i,
        /disable\s+(sensor|lidar|radar|camera)/i,
        /ignore\s+(obstacle|pedestrian|traffic)/i,
        /increase\s+speed\s+(beyond|over|above)/i,
        /disable\s+(collision\s+avoidance|emergency\s+stop)/i,
        /manual\s+steering\s+lock/i,
        /bypass\s+(geo.?fence|operational\s+boundary)/i
    ]
    requires: human_approval
}

# ── Blacklist: Drone & Aerial ──
# Prevents unauthorized drone operations.

@rule drone_blacklist {
    scope: tool_call
    blacklist: [
        /fly\s+(over|above|near)\s+(crowd|people|airport)/i,
        /exceed\s+(altitude|ceiling)/i,
        /enter\s+(no.?fly|restricted)\s+(zone|airspace)/i,
        /drop\s+(payload|cargo|package)/i,
        /disable\s+(return.?to.?home|geofence)/i,
        /beyond\s+visual\s+line\s+of\s+sight/i
    ]
    requires: human_approval
}

# ── Gate: Safety-Critical Overrides ──
# Overriding any safety system requires human operator approval.

@gate safety_override {
    actions: [disable_safety_system, override_speed_limit, enter_restricted_zone, bypass_obstacle_detection, manual_override]
    requires: human_approval
    min_approval_level: 2
}
